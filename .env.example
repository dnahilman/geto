# geto — environment (all optional; sensible defaults are set in docker-compose)

# Port the server listens on / is published at.
PORT=3100

# development | production. Use development for plain-HTTP self-hosting.
NODE_ENV=development

# Password for the login gate.
GETO_AUTH_PASSWORD=dev

# Optional. Derives the at-rest encryption key for saved DB passwords and signs
# the session cookie. A stable baked-in default is used if unset (fine for local
# use); set your own for real security and keep it stable (changing it makes
# previously-saved passwords undecryptable).
# GETO_MASTER_KEY=

# Directory for geto's own SQLite store (connections + query history).
GETO_DATA_DIR=./data

# Dev only: where the web dev server proxies the API. In prod the API is
# same-origin, so this is unused.
PUBLIC_API_URL=http://localhost:3100
