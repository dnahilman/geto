{
  "name": "geto",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "bun run --filter '*' --parallel dev",
    "dev:server": "bun run --filter @geto/server dev",
    "dev:web": "bun run --filter @geto/web dev",
    "build": "bun run --filter @geto/web build",
    "start": "bun run --filter @geto/server start",
    "format": "prettier --write \"apps/**/*.{ts,svelte,js,json,css}\""
  },
  "devDependencies": {
    "playwright-core": "^1.60.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "elysia": "1.4.28"
  }
}
